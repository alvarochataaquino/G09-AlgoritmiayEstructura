public class GestionZonas<T extends Comparable<T>> {
    private Paquete<T>[][] matriz;

    // Crea la matriz según los parámetros leídos por el Estudiante 1 [cite: 110]
    public GestionZonas(int filas, int columnas) {
        // En Java, la creación de arrays genéricos requiere este cast
        this.matriz = (Paquete<T>[][]) new Paquete[filas][columnas];
    }

    public void agregarPaquete(Paquete<T> p, int fila, int col) {
        matriz[fila][col] = p;
    }

    // Requerimiento 3.1: Mostrar la matriz de paquetes por zonas [cite: 78, 111]
    public void mostrarMatriz() {
        for (int i = 0; i < matriz.length; i++) {
            System.out.print("Zona " + (i + 1) + ": ");
            for (int j = 0; j < matriz[i].length; j++) {
                if (matriz[i][j] != null) {
                    System.out.print(matriz[i][j] + " ");
                }
            }
            System.out.println();
        }
    }

    public Paquete<T>[][] getMatriz() {
        return matriz;
    }
}
